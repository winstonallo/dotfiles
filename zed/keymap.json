[
    {
        "context": "Terminal",
        "bindings": {
            "super-[": "workspace::ActivatePreviousPane",
            "super-]": "workspace::ActivateNextPane",
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-shift-o": "pane::SplitRight",
        },
    },
    {
        "context": "Pane",
        "bindings": {
            "super-[": "pane::GoBack",
        },
    },
    {
        "context": "Pane",
        "unbind": {
            "ctrl-alt--": "pane::GoBack",
        },
    },
    {
        "context": "Pane",
        "bindings": {
            "super-]": "pane::GoForward",
        },
    },
]
