set ssl_starttls = yes
set ssl_force_tls = yes

set imap_user = "a.bied-charreton@proxmox.com"

set imap_pass = ""

set smtp_url = ""
set smtp_pass = "$imap_pass"
set from = "Arthur Bied-Charreton <a.bied-charreton@proxmox.com>"
set realname = "Arthur Bied-Charreton"
set folder = ""

set spoolfile = "+INBOX"
set postponed = "+Drafts"
set record="+Sent"
set header_cache = "~/Mail/cache/a.bied-charreton_proxmox.com/headers"
set message_cachedir = "~/Mail/cache/a.bied-charreton_proxmox.com/bodies"

set imap_check_subscribed = yes
set imap_list_subscribed = yes
set mail_check = 90
unset imap_passive

set sidebar_visible
set sidebar_format = "%B%<F? [%F]>%* %<N?%N/>%S"

macro index,pager \Cj "<sidebar-next><sidebar-open>" "Go to next sidebar folder"
macro index,pager \Ck "<sidebar-prev><sidebar-open>" "Go to previous sidebar folder"

set mail_check_stats

set sort=reverse-date-received

# Sad attempt at highlighting git diffs, it works okay but also colors lines starting
# with `-` outside of the diff red. It is not currently possible to interact with the
# content of the emails with Lua [1][2].
#
# [1] https://neomutt.org/feature/lua
# [2] https://github.com/neomutt/neomutt/pull/4707
color body cyan default "diff --git.*"
color body cyan default "^index [a-f0-9].*"
color body brightgreen default "^\-\-\- .*"
color body brightgreen default "^[\+]{3} .*"
color body brightgreen default "^[\+][^\+]+.*"
color body red default "^\-[^\-]+.*"
color body red default "^\-\-\-.*"
